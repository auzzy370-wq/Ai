# Optional: use OpenAI instead of the built-in mock responder
# OPENAI_API_KEY=sk-...

# Optional: override the default OpenAI model
# OPENAI_MODEL=gpt-4o-mini

# Optional: system prompt prepended to every conversation (OpenAI mode)
# SYSTEM_PROMPT=You are a helpful assistant.

# Optional: comma-separated CORS origins, or * for all origins
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
