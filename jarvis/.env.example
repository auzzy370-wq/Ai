# ============================================================
# JARVIS Neural Enterprise OS - Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# Core
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-strong-random-secret-key
LOG_LEVEL=info

# AI Models (Required for full functionality)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Vector Database
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=jarvis-memory

# Database
DATABASE_URL=postgresql+asyncpg://jarvis:jarvis_secret@localhost:5432/jarvis
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=jarvis
DATABASE_USER=jarvis
DATABASE_PASSWORD=jarvis_secret

# Redis
REDIS_URL=redis://localhost:6379/0

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Business Integrations (Optional)
# Stripe
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# HubSpot CRM
HUBSPOT_API_KEY=

# Google Ads
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=

# Meta/Facebook Ads
META_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Twitter/X
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=

# Google Analytics
GA_MEASUREMENT_ID=
GA_API_SECRET=

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Monitoring
SENTRY_DSN=
SLACK_WEBHOOK_URL=

# Security
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
CORS_ORIGINS=http://localhost:3000

# Voice
VOICE_MODEL=tts-1-hd
VOICE_ID=onyx
STT_MODEL=whisper-1
